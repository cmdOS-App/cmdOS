# ==========================================
# TaskLabs Open Source (OSS) Configuration
# ==========================================

# Build profile: Disable proprietary SaaS/Sharing UI and features
VITE_ENABLE_SHARING=false

# Google Drive Backup settings
VITE_ENABLE_GOOGLE_DRIVE_BACKUP=true

# Google OAuth Client ID for Google Drive Backup
# Set to your registered Chrome Extension OAuth Client ID
VITE_GOOGLE_CLIENT_ID=416092049746-e1aod0ppustla1ep5gvmvn7oimtsqfke.apps.googleusercontent.com

# Shared OSS Extension Public Key base64
# Locks the extension ID so the registered redirect URI matches for everyone.
# Get the key using: openssl rsa -pubout -in tasklabs-oss.pem -outform DER | openssl base64 -A
VITE_EXTENSION_PUBLIC_


# Local Server URL (Not used/needed for local-first mode)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_BYPASS_ONBOARDING=true
