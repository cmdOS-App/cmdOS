{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "ESLint",
  "extends": "./packages/tsconfig/base.json",
  "compilerOptions": {
    "noImplicitAny": false,
    "noEmit": true,
    "target": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@extension/ui": ["packages/ui/index.ts"],
      "@extension/ui/*": ["packages/ui/*"],
      "@private-services/*": ["src/storage/_private/API/services/*"],
      "@src/*": ["src/pages/AltS_search_newtab/src/*", "src/pages/AltS_search_websites/src/*", "src/pages/content-ui/src/*", "src/pages/popup/src/*", "src/pages/contentScript/src/*", "src/*"],
      "@private-providers/*": ["src/storage/_private/API/storage/providers/*"]
    }
  },
  "include": ["eslint.config.ts", "src/**/*"]
}
